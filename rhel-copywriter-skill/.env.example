# Red Hat Copywriter Skill — Environment Configuration
# Copy this file to .env and set values appropriate for your environment.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Standards reference version to load at runtime.
# Must match the version header in references/brand-and-tone-notes.md.
# Format: BT-YYYY-QN (e.g. BT-2026-Q2)
# ---------------------------------------------------------------------------
REDHAT_STANDARDS_VERSION=BT-2026-Q2

# ---------------------------------------------------------------------------
# Terminology list version to validate against.
# Must match the version header in references/brand-and-tone-notes.md (terminology section).
# Format: TERM-YYYY-QN (e.g. TERM-2026-Q2)
# ---------------------------------------------------------------------------
REDHAT_TERMINOLOGY_VERSION=TERM-2026-Q2

# ---------------------------------------------------------------------------
# Logging level for skill execution.
# Valid values: debug | info | warn | error
# Default: info
# ---------------------------------------------------------------------------
SKILL_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Output directory for generated copy artefacts (relative to project root).
# This directory is excluded from version control via .gitignore.
# Default: output/
# ---------------------------------------------------------------------------
SKILL_OUTPUT_DIR=output/

# ---------------------------------------------------------------------------
# Skill execution environment.
# Valid values: development | staging | production
# Default: development
# ---------------------------------------------------------------------------
SKILL_ENV=development
